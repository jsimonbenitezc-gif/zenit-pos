{
  "name": "zenit-pos",
  "version": "1.3.1",
  "description": "Sistema de registros y punto de venta digital.",
  "main": "pos/main.js",
  "author": "Zenit Software",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --publish never",
    "build-publish": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --publish always"
  },
  "build": {
    "appId": "com.zenit.pos",
    "productName": "Zenit POS",
    "icon": "graficos/zenit-icon.ico",
    "directories": {
      "output": "dist"
    },
    "files": [
      "pos/**/*",
      "database/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "sign": false,
      "publish": [
        "github"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "jsimonbenitezc-gif",
      "repo": "zenit-pos",
      "private": false
    }
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.7.9",
    "body-parser": "^1.20.3",
    "dotenv": "^16.4.7",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "express": "^4.21.2",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.1.9"
  }
}
